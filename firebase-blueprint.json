{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the system (Admin, Teacher, Parent, or Student)",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "teacher", "parent", "student"] },
        "schoolId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Course": {
      "title": "Course",
      "description": "A course or subject in a school",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "teacherId": { "type": "string" },
        "studentIds": { "type": "array", "items": { "type": "string" } },
        "schoolId": { "type": "string" },
        "grade": { "type": "string" }
      },
      "required": ["name", "teacherId", "schoolId"]
    },
    "Assignment": {
      "title": "Assignment",
      "description": "An assignment created by a teacher",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "courseId": { "type": "string" },
        "teacherId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["courseId", "teacherId", "title", "dueDate"]
    },
    "Submission": {
      "title": "Submission",
      "description": "A student's submission for an assignment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "assignmentId": { "type": "string" },
        "studentId": { "type": "string" },
        "content": { "type": "string" },
        "fileUrl": { "type": "string" },
        "grade": { "type": "string" },
        "feedback": { "type": "string" },
        "submittedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["assignmentId", "studentId", "submittedAt"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Attendance record for a course on a specific date",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "courseId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "records": { 
          "type": "object", 
          "description": "Map of studentId to status (present, absent, late)" 
        }
      },
      "required": ["courseId", "date", "records"]
    },
    "Fee": {
      "title": "Fee",
      "description": "Fee record for a student",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["paid", "pending", "overdue"] },
        "dueDate": { "type": "string", "format": "date" },
        "paidAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "amount", "status", "dueDate"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "School courses"
    },
    "/assignments/{assignmentId}": {
      "schema": "Assignment",
      "description": "Course assignments"
    },
    "/submissions/{submissionId}": {
      "schema": "Submission",
      "description": "Assignment submissions"
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Attendance records"
    },
    "/fees/{feeId}": {
      "schema": "Fee",
      "description": "Student fee records"
    }
  }
}
